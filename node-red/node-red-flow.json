    {
        "id": "ee655d97667d3813",
        "type": "function",
        "z": "22d480b0825fdd6a",
        "name": "format hourly UI (latest + 24h table)",
        "func": "const rows = Array.isArray(msg.payload) ? msg.payload : [];\nlet latest = rows[0];\nlet latestText = \"No hourly averages yet.\";\nif (latest) {\n latestText = `Last hourly average (${latest.hour_start}): Temp=${Number(latest.avg_temperature).toFixed(2)}°C, Hum=${Number(latest.avg_humidity).toFixed(2)}%, HI=${Number(latest.avg_heatindex).toFixed(2)}°C`;\n}\nlet html = `<div style=\"font-size:14px;\"><table style=\"width:100%; border-collapse:collapse;\"><thead><tr><th>Hour</th><th>Temp</th><th>Hum</th><th>HI</th></tr></thead><tbody>`;\nfor (const r of rows) {\n html += `<tr><td>${r.hour_start}</td><td>${Number(r.avg_temperature).toFixed(2)}</td><td>${Number(r.avg_humidity).toFixed(2)}</td><td>${Number(r.avg_heatindex).toFixed(2)}</td></tr>`;\n}\nhtml += `</tbody></table></div>`;\nreturn [{ payload: latestText }, { payload: html }];",
        "outputs": 2,
        "x": 560,
        "y": 760,
        "wires": [["23f8777818d9f65c"], ["ffd3e5fa48bea412"]]
    },
