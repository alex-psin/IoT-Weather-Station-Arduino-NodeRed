    {
        "id": "630b5dd6a7e646e1",
        "type": "function",
        "z": "22d480b0825fdd6a",
        "name": "function 2",
        "func": "// accept ONLY valid serial strings\nif (typeof msg.payload !== \"string\") return null;\n\nlet text = msg.payload.trim();\nif (text === \"\") return null;\n\n// Example expected text:\n// \"Humidity: 58.3% Temperature: 24.1°C Heat index: 25.0°C\"\n\nlet humidityMatch = text.match(/Humidity:\\s*([\\d.]+)%/);\nlet temperatureMatch = text.match(/Temperature:\\s*([\\d.]+)°C/);\nlet heatIndexMatch = text.match(/Heat index:\\s*([\\d.]+)°C/);\n\n// If any value is missing, ignore message\nif (!humidityMatch || !temperatureMatch || !heatIndexMatch) {\n    return null;\n}\n\nmsg.payload = {\n    humidity: Number(humidityMatch[1]),\n    temperature: Number(temperatureMatch[1]),\n    heatindex: Number(heatIndexMatch[1])\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 200,
        "y": 240,
        "wires": [["8d2e72ce8af4b913"]]
    },
