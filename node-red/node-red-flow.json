    {
        "id": "2caf9891567ed422",
        "type": "function",
        "z": "22d480b0825fdd6a",
        "name": "insert hourly averages (prev hour)",
        "func": "msg.topic = `INSERT OR REPLACE INTO hourly_averages (hour_start, avg_temperature, avg_humidity, avg_heatindex) SELECT strftime('%Y-%m-%d %H:00:00', 'now', '-1 hour') AS hour_start, AVG(temperature), AVG(humidity), AVG(heatindex) FROM measurements WHERE timestamp >= strftime('%Y-%m-%d %H:00:00', 'now', '-1 hour') AND timestamp < strftime('%Y-%m-%d %H:00:00', 'now') HAVING COUNT(*) > 0;`;\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 660,
        "wires": [["265b0122a30e1edc", "7908836fbed5bea3"]]
    },
