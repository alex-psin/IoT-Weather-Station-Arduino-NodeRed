    {
        "id": "b3aa840949d336a9",
        "type": "function",
        "z": "22d480b0825fdd6a",
        "name": "insert measurements (1/min)",
        "func": "const last = flow.get(\"last\");\nif (!last) {\n node.warn(\"NO flow.last\");\n return null;\n}\nconst t = Number(last.temperature);\nconst h = Number(last.humidity);\nconst hi = Number(last.heatindex);\nif ([t, h, hi].some(v => Number.isNaN(v))) {\n node.warn(\"NaN values in flow.last\");\n return null;\n}\nmsg.topic = \"INSERT INTO measurements(timestamp, temperature, humidity, heatindex) VALUES(datetime('now'), \" + t + \", \" + h + \", \" + hi + \");\";\nreturn msg;",
        "outputs": 1,
        "x": 490,
        "y": 480,
        "wires": [["265b0122a30e1edc"]]
    },
